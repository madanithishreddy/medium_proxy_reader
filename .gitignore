# Miscellaneous
*.class
*.log
*.pyc
*.swp
*.tmp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Common local environment files
.env
.env.*

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub-cache/
.pub/
.packages
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/local.properties

# Android release signing secrets
/android/key.properties
*.jks
*.keystore

# iOS build/generated files
/ios/Flutter/ephemeral/
/ios/Flutter/flutter_export_environment.sh

# macOS/Linux/Windows generated plugin registrants can be regenerated
/linux/flutter/generated_plugin_registrant.*
/macos/Flutter/GeneratedPluginRegistrant.swift
/windows/flutter/generated_plugin_registrant.*
